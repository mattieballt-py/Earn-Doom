{
  "manifest_version": 3,
  "name": "Your Extension",
  "version": "1.0.0",
  "description": "Extension description",
  "permissions": [],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Your Extension"
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"]
    }
  ]
}
